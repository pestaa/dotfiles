background-opacity = 0.9
background-opacity-cells = true
cursor-style-blink = false
cursor-style = block
font-size = 12
keybind = global:super+0=toggle_quick_terminal
keybind = global:super+enter=new_window
keybind = global:super+`=toggle_quick_terminal
keybind = super+h=goto_split:left
keybind = super+j=goto_split:bottom
keybind = super+k=goto_split:top
keybind = super+l=goto_split:right
keybind = super+shift+h=new_split:left
keybind = super+shift+j=new_split:down
keybind = super+shift+k=new_split:up
keybind = super+shift+l=new_split:right
maximize = true
mouse-hide-while-typing = true
quick-terminal-position = top
quick-terminal-size = 40%
quit-after-last-window-closed = false
shell-integration-features = no-cursor
theme = light:TokyoNight Day, dark:TokyoNight Moon
window-decoration = none
window-padding-color = background
window-padding-x = 4
window-padding-y = 4
